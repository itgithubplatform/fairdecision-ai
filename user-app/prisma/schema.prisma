model ApiKey {
  id        String   @id @default(cuid())
  keyHash   String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  isActive  Boolean  @default(true)

  @@index([userId])
}

model CustomRule {
  id          String   @id @default(cuid())
  ruleText    String   @db.Text 
  category    String   @default("General Compliance")
  isActive    Boolean  @default(true) 
  isSystem    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model RequestLog {
  id            String   @id @default(cuid())
  userId        String
  prompt        String   @db.Text
  decision      String   
  latency       Float
  violationData Json   
  
  isProcessed   Boolean  @default(false)
  auditorStatus String?  
  auditorNotes  String?  @db.Text

  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)]) 
  @@index([decision])           
  @@index([isProcessed])               
}

model CsvBatch {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  totalRows   Int      @default(0)
  processed   Int      @default(0)
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  records     CsvRecord[]
}

model CsvRecord {
  id               String   @id @default(cuid())
  batchId          String
  originalRow      String
  textToEvaluate   String
  
  action           String?  
  threatLabel      String?
  threatScore      Float?
  ruleMatched      String?
  ruleScore        Float?
  
  status           String   @default("PENDING")
  createdAt        DateTime @default(now())
  processedAt      DateTime?

  batch            CsvBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
}